*.db-shm
*.db-wal
*.db.bak*
*.sqlite3
# Compose-Bind-Mounts (App-Daten + PostgreSQL-Datenverzeichnis)
/data/
/db/
# Isolierter Test-Cluster von tools/pg-test.ps1 (eigener Port, wegwerfbar)
backend/_pgtest/

# Python
__pycache__/
*.py[cod]
.venv/
venv/

