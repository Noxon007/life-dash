# Life-Dash Backend — Beispiel-Konfiguration
# Kopiere diese Datei nach .env und passe Werte an.

# Datenbank (MVP: SQLite-Datei). Für Postgres z. B.:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/lifedash
DATABASE_URL=sqlite:///./lifedash.db

# KI-Provider: "mock" (Standard) oder später "ollama"
AI_PROVIDER=mock

# Ollama (nur relevant, wenn AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Beim Start Demo-Daten einspielen
SEED_DEMO=true

# Confidence-Schwelle: darunter -> needs_review
CONFIDENCE_REVIEW_THRESHOLD=0.75
