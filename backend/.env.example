# Life-Dash Backend — Beispiel für die LOKALE ENTWICKLUNG (ohne Docker).
# Kopiere diese Datei nach backend/.env und passe Werte an.
#
# Für ein Server-Deployment ist NICHT diese Datei die Referenz, sondern die
# ../.env.example im Repo-Wurzelverzeichnis — dort steht jede unterstützte
# Einstellung. Hier steht nur, was man zum lokalen Loslegen braucht.

# Kein Login, fester Dev-User mit Admin-Rechten — nur lokal verwenden!
AUTH_MODE=dev

# SQLite-Datei reicht lokal. Postgres ginge auch:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/lifedash
DATABASE_URL=sqlite:///./lifedash.db

# KI: "mock" arbeitet regelbasiert und braucht keinen Key — der einfachste
# Start. Für echte Analyse "openai" setzen und einen OpenAI-kompatiblen
# Endpoint eintragen (Beispiele: siehe ../.env.example).
AI_PROVIDER=mock
#OPENAI_BASE_URL=http://localhost:1234/v1
#OPENAI_API_KEY=
#OPENAI_MODEL=

# Semantische Suche (optional) — leer = nur Volltextsuche
#OPENAI_EMBED_MODEL=

# Beim Start Demo-Daten einspielen (praktisch für eine leere Entwicklungs-DB)
SEED_DEMO=true

# Konfidenz-Schwelle: darunter landet ein KI-Vorschlag in der Moderation
CONFIDENCE_REVIEW_THRESHOLD=0.75

# Ortsnamen auflösen. Standard ist der öffentliche OSM-Nominatim (kein Key,
# max. 1 Anfrage/s). Ein Nominatim-kompatibler Dienst mit Key (z. B.
# LocationIQ) oder eine eigene Instanz gehen genauso — nur die URL tauschen.
GEOCODING_ENABLED=true
#GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
#GEOCODER_API_KEY=

# Ausführlichkeit der Logs: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
