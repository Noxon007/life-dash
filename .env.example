# Life-Dash Konfiguration (für docker compose)
# Kopieren nach .env und Werte anpassen. Diese Datei ist die maßgebliche
# Setup-Referenz — jede unterstützte Einstellung steht hier.
#
# Genannte Produkte sind Beispiele, keine Voraussetzung: Life-Dash spricht
# Standard-Protokolle (OIDC, OpenAI-kompatible API, Nominatim) und läuft mit
# jedem Anbieter, der sie beherrscht.

# ---------------------------------------------------------------- #
# Deployment
# ---------------------------------------------------------------- #
# Image-Tag aus GHCR. Vier sinnvolle Werte:
#   0.32.0  exakte Version — in Produktion die richtige Wahl
#   0.32    mitlaufend im Minor (bekommt Fehlerbehebungen, keine Features)
#   latest  die jeweils neueste Veröffentlichung
#   main    der aktuelle Entwicklungsstand — zum Ausprobieren, nicht für Daten,
#           die dir wichtig sind (siehe docs/DEPLOY.md, „Testing a change")
# Aktualisieren: Wert hochsetzen, dann `docker compose pull && up -d`.
LIFEDASH_VERSION=0.32.0
# Host-Port, auf dem die App lauscht (das Ziel für deinen Reverse Proxy)
LIFEDASH_PORT=8000
TZ=Europe/Berlin
# Ausführlichkeit der App-Logs (A9): DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------- #
# Auth — drei Betriebsarten (AUTH_MODE):
#   local -> E-Mail + Passwort, OHNE Identitätsanbieter (A35). Der erste
#            registrierte Nutzer wird Admin; weitere Konten legt er in der
#            Verwaltung an. Am einfachsten für den Einstieg — kein OIDC nötig.
#   oidc  -> Login über einen standardkonformen OIDC-Provider (Authentik,
#            Keycloak, Pocket ID, Zitadel, Auth0, ...). Dort einen Client anlegen:
#              Name:          Life-Dash
#              Callback-URL:  <PUBLIC_BASE_URL>/api/auth/callback
#              Public Client: ja (PKCE) — dann OIDC_CLIENT_SECRET leer lassen
#   dev   -> kein Login, fester Dev-User. NUR lokale Entwicklung, nie öffentlich.
#
#   Bei local UND oidc gilt: SESSION_SECRET unbedingt setzen (siehe unten) —
#   damit werden die Session-Cookies signiert.
# ---------------------------------------------------------------- #
AUTH_MODE=local
# --- Die folgenden OIDC_* nur bei AUTH_MODE=oidc nötig ---
# Basis-URL des Providers (Discovery unter /.well-known/openid-configuration)
OIDC_ISSUER=https://id.example.com
OIDC_CLIENT_ID=life-dash
OIDC_CLIENT_SECRET=
# Anzeigename des Providers auf dem Login-Screen (rein kosmetisch);
# leer = neutraler Text „per SSO anmelden"
#OIDC_PROVIDER_NAME=
# URL, unter der Life-Dash im Browser erreichbar ist — muss exakt der Domain
# entsprechen, die dein Reverse Proxy bedient, sonst schlägt der OIDC-Callback fehl.
# Mit https:// werden Session-Cookies automatisch auf Secure gestellt.
PUBLIC_BASE_URL=https://life.example.com
# Langer Zufallswert, z. B.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me
# Wie lange eine Anmeldung gültig bleibt
#SESSION_MAX_AGE_DAYS=30

# ---------------------------------------------------------------- #
# KI — beliebiger OpenAI-kompatibler Endpoint
#   AI_PROVIDER=mock schaltet die KI ab (regelbasiert, kein Key nötig) —
#   der einfachste Start und gut für einen ersten Smoke-Test.
#   AI_PROVIDER=openai nutzt OPENAI_BASE_URL/-MODEL/-API_KEY.
#
#   Beispiel-Endpoints (BASE_URL / typisches MODEL):
#     OpenAI     https://api.openai.com/v1                                  gpt-4o-mini
#     Gemini     https://generativelanguage.googleapis.com/v1beta/openai    gemini-3.5-flash
#     Ollama     http://localhost:11434/v1                                  llama3.1
#     LM Studio  http://localhost:1234/v1                                   local-model
#   Cloud-Anbieter drosseln im Free-Tier teils deutlich (z. B. ~10 Anfragen/Minute).
# ---------------------------------------------------------------- #
AI_PROVIDER=mock
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Ab welcher Konfidenz ein KI-Vorschlag ohne Nachfrage durchgeht
#CONFIDENCE_REVIEW_THRESHOLD=0.75

# --- Embeddings für die semantische Suche (optional) ---
# Leer = keine Embeddings, die Suche fällt auf Volltext zurück.
OPENAI_EMBED_MODEL=
# Embeddings dürfen auf einem ANDEREN Endpoint laufen als der Chat (z. B. lokal
# einbetten, in der Cloud analysieren). Leer = wie der Chat-Endpoint.
OPENAI_EMBED_BASE_URL=
OPENAI_EMBED_API_KEY=
# Manche Modelle brauchen Präfixe (nomic-embed-text: "search_query: " /
# "search_document: "); bge-m3 und die meisten anderen: leer lassen.
OPENAI_EMBED_QUERY_PREFIX=
OPENAI_EMBED_DOC_PREFIX=
# Mindest-Ähnlichkeit für semantische Treffer. Modellabhängig kalibrieren:
# 0.4 passt zu bge-m3; für andere Modelle empirisch nachziehen.
SEMANTIC_MIN_SIMILARITY=0.4

# ---------------------------------------------------------------- #
# Geocoding — Ortsnamen und Adressen auflösen
# ---------------------------------------------------------------- #
GEOCODING_ENABLED=true
# Standard: öffentlicher OSM-Nominatim (kein Key, max. 1 Anfrage/s — drosselt
# bei Volumen mit HTTP 429). Alternativ ein Nominatim-kompatibler Dienst mit
# Key (z. B. LocationIQ) oder eine selbst gehostete Nominatim-Instanz —
# gleiche API, nur die Basis-URL tauschen.
#GEOCODER_BASE_URL=https://nominatim.openstreetmap.org
#GEOCODER_API_KEY=

# ---------------------------------------------------------------- #
# Datenbank: PostgreSQL (Standard). Passwort setzen, z. B.:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Die DATABASE_URL wird in der Compose automatisch daraus gebaut —
# nur setzen, wenn sie abweichen soll (z. B. SQLite für Minimal-Setups:
#   DATABASE_URL=sqlite:////data/lifedash.db
#   + Start mit: docker compose up -d --no-deps app).
# ---------------------------------------------------------------- #
POSTGRES_PASSWORD=change-me
# DATABASE_URL=

# Beim allerersten Start Demo-Daten anlegen (für einen leeren Produktivbetrieb: false)
SEED_DEMO=false

# ---------------------------------------------------------------- #
# Bilder (F15): Verzeichnis für hochgeladene Fotos.
# ACHTUNG — hier liegen die EINZIGEN Daten, die der JSON-Export nicht
# enthalten kann. Eigenes Volume, eigene Sicherung (siehe docs/DEPLOY.md).
# ---------------------------------------------------------------- #
# MEDIA_DIR=/data/media
# MEDIA_MAX_MB=25
# MEDIA_THUMB_PX=640

# ---------------------------------------------------------------- #
# Immich (P2.1): kein Server-Setting — URL und API-Schlüssel werden
# PRO NUTZER in der App hinterlegt (Verwaltung → Meine Daten → Immich),
# weil in einem Mehrpersonen-Setup jeder seine eigene Bibliothek hat.
# ---------------------------------------------------------------- #
