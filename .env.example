# Life-Dash Konfiguration (für docker compose bzw. backend/.env)
# Kopieren nach .env und Werte anpassen.

# ---------------------------------------------------------------- #
# Deployment
# ---------------------------------------------------------------- #
# Image-Tag aus GHCR — SemVer: exakt (0.3.0) oder mitlaufend im Minor (0.3).
# In Produktion pinnen, nicht "latest". Update: Tag hochsetzen + docker compose pull.
LIFEDASH_VERSION=0.7.0
# Host-Port, auf dem die App lauscht (Ziel für Pangolin/Traefik)
LIFEDASH_PORT=8000
TZ=Europe/Berlin
# Ausführlichkeit der App-Logs (A9): DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---------------------------------------------------------------- #
# Auth — Multi-User via OIDC (Pocket ID)
#   In Pocket ID einen OIDC-Client anlegen:
#     Name:          Life-Dash
#     Callback-URL:  <PUBLIC_BASE_URL>/api/auth/callback
#     Public Client: ja (PKCE) — dann OIDC_CLIENT_SECRET leer lassen
#   Für lokale Entwicklung ohne Login: AUTH_MODE=dev
# ---------------------------------------------------------------- #
AUTH_MODE=oidc
OIDC_ISSUER=https://id.example.home
OIDC_CLIENT_ID=life-dash
OIDC_CLIENT_SECRET=
# URL, unter der Life-Dash im Browser erreichbar ist (Pangolin-Domain!)
# Mit https:// werden Session-Cookies automatisch auf Secure gestellt.
PUBLIC_BASE_URL=https://life.example.com
# Langer Zufallswert, z. B.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me

# ---------------------------------------------------------------- #
# KI — Standardweg: Gemini API (OpenAI-kompatibler Endpoint)
#   Key holen:  https://aistudio.google.com/apikey  -> in OPENAI_API_KEY
#   OPENAI_MODEL=gemini-3.5-flash (Stand 07/2026; 2.5-flash ist für
#   neue Accounts gesperrt). Free-Tier drosselt auf ~10 Anfragen/Minute.
#
#   AI_PROVIDER=mock schaltet die KI ab (regelbasiert, kein Key nötig) —
#   nützlich für einen ersten Smoke-Test ohne Gemini-Key.
#   Ein anderer OpenAI-kompatibler Endpoint (lokales Ollama o. Ä.) ist
#   weiterhin möglich: einfach OPENAI_BASE_URL/-MODEL umstellen.
# ---------------------------------------------------------------- #
AI_PROVIDER=openai
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
OPENAI_API_KEY=
OPENAI_MODEL=gemini-3.5-flash
# Embedding-Modell für semantische Suche (leer = nur Volltext)
OPENAI_EMBED_MODEL=gemini-embedding-2
# Embeddings können auf einem ANDEREN Endpoint laufen als der Chat. Leer = wie Chat.
OPENAI_EMBED_BASE_URL=
OPENAI_EMBED_API_KEY=
# Mindest-Ähnlichkeit für semantische Treffer (0.6 für gemini-embedding-2, unkalibriert)
SEMANTIC_MIN_SIMILARITY=0.6
# Nominatim-Geocoding für präzise Adressen
GEOCODING_ENABLED=true

# ---------------------------------------------------------------- #
# Datenbank: PostgreSQL (Standard). Passwort setzen, z. B.:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
# Die DATABASE_URL wird in der Compose automatisch daraus gebaut —
# nur setzen, wenn sie abweichen soll (z. B. SQLite für Minimal-Setups:
#   DATABASE_URL=sqlite:////data/lifedash.db
#   + Start mit: docker compose up -d --no-deps app).
# ---------------------------------------------------------------- #
POSTGRES_PASSWORD=change-me
# DATABASE_URL=

SEED_DEMO=false
