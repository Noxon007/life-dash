# Life-Dash Konfiguration (für docker compose bzw. backend/.env)
# Kopieren nach .env und Werte anpassen.

# ---------------------------------------------------------------- #
# Deployment
# ---------------------------------------------------------------- #
# Image-Tag aus GHCR (Update: neuen Tag eintragen + docker compose pull)
LIFEDASH_VERSION=v0.1
# Host-Port, auf dem die App lauscht (Ziel für Pangolin/Traefik)
LIFEDASH_PORT=8000
TZ=Europe/Berlin

# ---------------------------------------------------------------- #
# Auth — Multi-User via OIDC (Pocket ID)
#   In Pocket ID einen OIDC-Client anlegen:
#     Name:          Life-Dash
#     Callback-URL:  <PUBLIC_BASE_URL>/api/auth/callback
#     Public Client: ja (PKCE) — dann OIDC_CLIENT_SECRET leer lassen
#   Für lokale Entwicklung ohne Login: AUTH_MODE=dev
# ---------------------------------------------------------------- #
AUTH_MODE=oidc
OIDC_ISSUER=https://id.example.home
OIDC_CLIENT_ID=life-dash
OIDC_CLIENT_SECRET=
# URL, unter der Life-Dash im Browser erreichbar ist (Pangolin-Domain!)
# Mit https:// werden Session-Cookies automatisch auf Secure gestellt.
PUBLIC_BASE_URL=https://life.example.com
# Langer Zufallswert, z. B.:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me

# ---------------------------------------------------------------- #
# KI-Provider: mock (regelbasiert) | openai (jeder OpenAI-kompatible
# Endpoint: Ollama /v1, LM Studio, OpenAI, Gemini ...)
#   Ollama lokal:  http://localhost:11434/v1 (Container: http://ollama:11434/v1)
#   Gemini API:    https://generativelanguage.googleapis.com/v1beta/openai
#                  + OPENAI_API_KEY von https://aistudio.google.com/apikey
#                  + OPENAI_MODEL=gemini-3.5-flash (Stand 07/2026;
#                    2.5-flash ist für neue Accounts gesperrt)
# ---------------------------------------------------------------- #
AI_PROVIDER=mock
OPENAI_BASE_URL=http://ollama:11434/v1
OPENAI_API_KEY=not-needed
OPENAI_MODEL=gemma3:12b
# Embedding-Modell für semantische Suche (leer = nur Volltext)
#   vorher einmalig:  ollama pull bge-m3   (multilingual, gut für Deutsch)
OPENAI_EMBED_MODEL=bge-m3
# Embeddings können auf einem ANDEREN Endpoint laufen als der Chat
# (z. B. Chat -> Gemini, Embeddings -> lokales Ollama). Leer = wie Chat.
OPENAI_EMBED_BASE_URL=
OPENAI_EMBED_API_KEY=
# Mindest-Ähnlichkeit für semantische Treffer: 0.4 für bge-m3,
# 0.6 für gemini-embedding-2 (unkalibriert)
SEMANTIC_MIN_SIMILARITY=0.4
# Nominatim-Geocoding für präzise Adressen
GEOCODING_ENABLED=true

# ---------------------------------------------------------------- #
# Datenbank: SQLite (Default) oder Postgres (compose-Profil "postgres")
# ---------------------------------------------------------------- #
DATABASE_URL=sqlite:////data/lifedash.db
# DATABASE_URL=postgresql+psycopg2://lifedash:lifedash@db:5432/lifedash
# POSTGRES_PASSWORD=lifedash

SEED_DEMO=false
